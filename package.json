{
  "name": "heroi-kiosk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "kiosk:edge": "powershell -ExecutionPolicy Bypass -File ./scripts/launch-edge-kiosk.ps1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.3",
    "@types/howler": "^2.2.12",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "preact": "^10.28.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@types/morphdom": "^2.3.0",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "lottie-web": "^5.13.0",
    "morphdom": "^2.7.8",
    "phaser": "^3.90.0",
    "pixi.js": "^8.16.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
